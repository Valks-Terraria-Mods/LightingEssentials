			Tooltip: Brightness multiplier for Plantera jungle.
		}

		BossMechEffects: {
			Label: Mech Boss Effects
			Tooltip: After mech bosses are defeated, brightens hardmode ore tiles.
		}

		BossMechEffectsMultiplier: {
