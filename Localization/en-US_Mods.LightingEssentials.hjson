Configs: {
	Config: {
		DisplayName: Config

		ModEnabled: {
			Label: Mod Enabled
			Tooltip: Enables all Lighting Essentials effects.
		}

		PlayerLight: {
			Label: Player Light
			Tooltip: Light color emitted by the player.
		}

		BossEyeofCthulhuEffects: {
			Label: Eye Of Cthulhu Effects
			Tooltip: After Eye Of Cthulhu is defeated, brightens grass and plants.
		}

		BossEyeofCthulhuEffectsMultiplier: {
			Label: Eye Of Cthulhu Multiplier
			Tooltip: Brightness multiplier after killing Eye Of Cthulhu.
		}

		BossEvilBiomeEffects: {
			Label: Evil Biome Effects
			Tooltip: After evil biome boss is defeated, brightens corruption and crimson tiles.
		}

		BossEvilBiomeEffectsMultiplier: {
			Label: Evil Biome Multiplier
			Tooltip: Brightness multiplier for the boss evil biome.
		}

		BossSkeletronEffects: {
			Label: Skeletron Effects
			Tooltip: After Skeletron is defeated, brightens meteorite tiles.
		}

		BossSkeletronEffectsMultiplier: {
			Label: Skeletron Multiplier
			Tooltip: Brightness multiplier for Skeletron.
		}

		BossPlanteraEffects: {
			Label: Plantera Effects
			Tooltip: After Plantera is defeated, brightens jungle tiles.
		}

		BossPlanteraEffectsMultiplier: {
